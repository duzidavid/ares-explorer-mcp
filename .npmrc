# mcp-handler@1.1.0 pins @modelcontextprotocol/sdk to exactly 1.26.0, while
# @modelcontextprotocol/ext-apps requires ^1.29.0. The APIs mcp-handler uses
# (McpServer + Streamable HTTP transport) are stable across those versions, so we
# keep 1.29.x and relax peer resolution. Vercel reads this file at install time too.
legacy-peer-deps=true
